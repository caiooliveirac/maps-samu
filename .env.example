# ============================================
# MAPS-SAMU Environment Configuration
# Copy to .env and fill in values
# ============================================

# PostgreSQL
POSTGRES_USER=samu
POSTGRES_PASSWORD=samu_secure_2024
POSTGRES_DB=maps_samu
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://samu:samu_secure_2024@db:5432/maps_samu

# Backend
BACKEND_PORT=8000
BACKEND_WORKERS=4
LOG_LEVEL=info
CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:80

# Frontend
VITE_API_URL=/api
VITE_MAP_CENTER_LAT=-12.9714
VITE_MAP_CENTER_LNG=-38.5124
VITE_MAP_DEFAULT_ZOOM=12

# Nominatim (geocoding) — usar instância local em produção
NOMINATIM_URL=https://nominatim.openstreetmap.org

# Timezone
TZ=America/Bahia
